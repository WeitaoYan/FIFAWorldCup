{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "strict": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "baseUrl": "."
  },
  "include": ["app/**/*.ts", "app/**/*.tsx"]
}
